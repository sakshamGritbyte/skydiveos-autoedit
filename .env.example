# Claude API — used by /edl to generate the Edit Decision List
ANTHROPIC_API_KEY=

# S3-compatible object store for raw + rendered media
S3_BUCKET=
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Celery broker / result backend. /ingest also LPUSHes ready_for_processing
# events onto a Redis list here; without it, events fall back to a local file.
REDIS_URL=redis://localhost:6379/0

# Where /ingest stages pulled camera media: <root>/{camera_id}/{date}/{filename}
RAW_STORAGE_ROOT=./raw-storage

# SkydiveOS web layer — pipeline calls back here on job state changes
SKYDIVEOS_API_BASE=http://localhost:3000

# Camera auto-discovery (ingest/discovery.py). When ENABLE_AUTO_DISCOVERY is on,
# the API BLE-scans every DISCOVERY_INTERVAL_SECONDS for *paired* cameras (the
# allow-list in MongoDB) and auto-pulls + processes them. Off by default.
ENABLE_AUTO_DISCOVERY=false
DISCOVERY_INTERVAL_SECONDS=30
# Scanner / transport: "ble" (wireless: BLE scan + WiFi pull, real GoPros),
# "usb" (kiosk: mDNS detect a USB-connected GoPro + wired pull), or "static" — a
# no-hardware simulation that scans DISCOVERY_FAKE_CAMERAS and stages
# DISCOVERY_SAMPLE_MP4 in place of a real download. ble/usb need the hardware SDK.
CAMERA_SCANNER=ble
DISCOVERY_FAKE_CAMERAS=1234
DISCOVERY_SAMPLE_MP4=sample-data/discovery_sample.mp4
# MongoDB holding the paired-camera registry (the `cameras` collection). The
# mongodb+srv:// form needs pymongo[srv]/dnspython. Unset → registry disabled.
MONGO_URL=
MONGO_DB=skydiveos

# Enforce per-instructor access scoping using identity SkydiveOS forwards
# (X-Instructor-Id + X-Role headers). Off → every caller is treated as admin
# (open, back-compatible). Turn on once SkydiveOS forwards the headers.
ENFORCE_INSTRUCTOR_AUTH=false

# Use a validated GoPro LRV proxy for the ANALYSIS stages (GPMF parsing, scene
# segmentation, exit/freefall/canopy detection, face/smile/eye scoring) when one is
# present beside the master and passes validation (matching LRV, duration within 0.1s,
# readable video + GPMF). Any failure falls back to the MP4 transparently. Rendering,
# EDL application, photo extraction, and all deliverables ALWAYS use the original MP4.
# Off by default — analysis reads the MP4 exactly as today.
USE_PROXY_ANALYSIS=false
