# Claude API — used by /edl to generate the Edit Decision List
ANTHROPIC_API_KEY=

# S3-compatible object store for raw + rendered media
S3_BUCKET=
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Celery broker / result backend. /ingest also LPUSHes ready_for_processing
# events onto a Redis list here; without it, events fall back to a local file.
REDIS_URL=redis://localhost:6379/0

# Where /ingest stages pulled camera media: <root>/{camera_id}/{date}/{filename}
RAW_STORAGE_ROOT=./raw-storage

# SkydiveOS web layer — pipeline calls back here on job state changes
SKYDIVEOS_API_BASE=http://localhost:3000
